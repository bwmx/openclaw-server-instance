# Copy to .env and fill in. scripts/setup.sh generates this for you.

# Base image for the gateway build.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Shared secret for the OpenClaw gateway API/Control UI.
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# Secret for the public pairing page. The QR page only works at:
#   http://<server-ip>:<PAIR_PUBLIC_PORT>/?token=<PAIR_TOKEN>
# Generate with: openssl rand -hex 24
PAIR_TOKEN=

# Public port for the pairing page (the only publicly exposed port).
PAIR_PUBLIC_PORT=8377

# Pairing session lifetime in ms (default 15 minutes).
PAIR_SESSION_TTL_MS=900000

# Optional: override the Liquid Auth signaling server
# (default inside the plugin: https://debug.liquidauth.com)
AC2_LIQUID_AUTH_SERVER=
