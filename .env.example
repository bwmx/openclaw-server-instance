# Copy to .env and fill in. scripts/setup.sh generates this for you.

# Public domain name (A record pointed at this server, proxied through
# Cloudflare). Used by Caddy to serve on the right hostname.
# OPTIONAL: leave blank for local / private use (no Caddy, no TLS).
# When set, scripts/setup.sh starts Caddy and serves the pair page at
# https://<DOMAIN>. When blank, the pair page is at http://localhost:8377.
DOMAIN=

# Base image for the gateway build.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Shared secret for the OpenClaw gateway API/Control UI.
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# Secret for the public pairing page. The QR page only works at:
#   https://<DOMAIN>/?token=<PAIR_TOKEN>
# Generate with: openssl rand -hex 24
PAIR_TOKEN=

# Pairing session lifetime in ms (default 15 minutes).
PAIR_SESSION_TTL_MS=900000

# Optional: override the Liquid Auth signaling server
# (default inside the plugin: https://debug.liquidauth.com)
AC2_LIQUID_AUTH_SERVER=

# Google AI (Gemini) API key — enables fully non-interactive setup.
# Get one at: https://aistudio.google.com/app/apikey
# When set, scripts/setup.sh skips the interactive onboarding walkthrough.
GOOGLE_API_KEY=

# Default Gemini model to use (optional; leave blank for OpenClaw's built-in default).
# Examples: gemini-2.5-pro-preview  gemini-2.0-flash
GOOGLE_MODEL=

# Set to true to expose the ac2 pair process log tail in the pairing page UI.
# Useful for local debugging. Leave unset (or false) on public instances to
# avoid leaking agent chat output through the browser.
PAIR_SHOW_LOGS=
